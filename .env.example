# Copy to .env.local locally; set the same keys in Vercel → Project → Settings → Environment Variables.

# --- Supabase (server only — never NEXT_PUBLIC_* these) ---
# Dashboard → Settings → API: Project URL + service_role key
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Mail (receipts) — Gmail OR Resend ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
# RESEND_API_KEY=
# RECEIPT_EMAIL_FROM=

# --- Site URL for receipt HTML @font-face (Baby Doll). Vercel sets VERCEL_URL if you skip this. ---
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# RECEIPT_FONT_BASE_URL=https://yourdomain.com

# RSVP fee (whole dollars); falls back to DEFAULT_RSVP_PRICE_DOLLARS in code
# RSVP_PRICE_DOLLARS=5

# Show maintenance page when "true"
# MAINTENANCE_FLAG=false
